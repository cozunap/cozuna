rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'cmozunap@gmail.com';
    }
    match /pages/{document} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == 'cmozunap@gmail.com';
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
